      "source": [
        "# Figure 5 — ReLU model prediction vs data (time series + scatter)\n",
        "fig, axes = plt.subplots(1, 2, figsize=(14, 4))\n",
        "fig.suptitle('Figure 5 — ReLU Model vs Data', fontsize=15)\n",
        "\n",
        "# Left panel: time series — compare the ReLU-clipped prediction to the true PSTH\n",
        "axes[0].plot(time_te * dt, psth_te,     linewidth=2,   color=MAT_COL[1], label='Data')\n",
        "axes[0].plot(time_te * dt, f_relu / dt, linewidth=1.5, color=MAT_COL[2], label='ReLU model')\n",
        "axes[0].set_xlim([time_te[0] * dt, time_te[0] * dt + 5])   # zoom into first 5 s\n",
        "axes[0].set_xlabel('Time (s)')\n",
        "axes[0].set_ylabel('Spiking Rate (Hz)')\n",
        "axes[0].set_title('Spiking rate: Data vs ReLU model')\n",
        "axes[0].legend()\n",
        "\n",
        "# Right panel: scatter — all predictions should now be ≥ 0 (no points below x-axis)\n",
        "axes[1].scatter(psth_te, f_relu / dt, s=8, alpha=0.5)\n",
        "lim = [min(psth_te.min(), (f_relu/dt).min()),\n",
        "       max(psth_te.max(), (f_relu/dt).max())]   # shared axis limits\n",
        "axes[1].plot(lim, lim, '--k')                    # identity line\n",
        "axes[1].set_xlabel('PSTH (Hz)')\n",
        "axes[1].set_ylabel('ReLU prediction (Hz)')\n",
        "axes[1].set_title('Scatter: Data vs ReLU prediction')\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.show()\n"
      ],
